# Copy to .dev.vars (Cloudflare Workers) and fill in real values.
# Never commit real secrets.

# Auth (better-auth)
BETTER_AUTH_SECRET=replace-with-32+char-random-string
BETTER_AUTH_URL=http://localhost:8787

# OAuth providers (optional in dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# AI is BYOK — users supply their own Gemini key from the UI.
# This env var is optional and only used for background/non-user jobs.
GEMINI_API_KEY=
